<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}K-Pop Music Quiz
			{% endblock %}
		</title>
		{% block stylesheets %}{% endblock %}
		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body>
		<nav class="navbar" role="navigation" aria-label="main navigation">
			<div class="navbar-brand">
				<a class="navbar-item" href="#">
					<img src="{{ asset('images/logo.png') }}">
					K-pop Music Quiz
				</a>
			</div>
			<a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbar">
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
				<span aria-hidden="true"></span>
			</a>
			<div id="navbar" class="navbar-menu">
				<div class="navbar-start">
					<a class="navbar-item" href="{{ path('app_home') }}">Play</a>
					<a class="navbar-item" href="{{ path('app_score') }}">Scoreboard</a>
				</div>
				{# <div class="navbar-end">
																	<div class="navbar-item">
																		<div class="buttons">
																			<a class="button is-primary" href="#">
																				<strong>Sign up</strong>
																			</a>
																			<a class="button is-light" href="#">
																				Log in
																			</a>
																		</div>
																	</div>
																</div> #}
			</div>
		</nav>
		<section class="section">
			<div class="container">
				{% for label, messages in app.flashes %}
					{% for message in messages %}
						<div class="notification is-{{ label }}">
							<button class="delete"></button>
							{{ message }}
						</div>
					{% endfor %}
				{% endfor %}
				{% block body %}{% endblock %}
			</div>
		</section>
		<footer class="footer">
			<div class="content has-text-centered">
				<p>
					Made with &hearts; by
					<a href="https://twitter.com/Aimaak_">Aimak</a>
				</p>
				<a href="https://www.flaticon.com/free-icons/kpop" title="kpop icons">Kpop icons created by Freepik - Flaticon</a>
			</div>
		</footer>
	</body>
</html>
